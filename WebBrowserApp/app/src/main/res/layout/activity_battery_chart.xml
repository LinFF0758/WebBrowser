<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/battery_chart_title"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_refresh_chart"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/refresh"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <Button
            android:id="@+id/btn_reset_zoom"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/reset_zoom"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/chart_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#666"
        android:layout_marginBottom="4dp"
        android:text="@string/loading" />

    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/line_chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="8dp">

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="#FF2196F3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/battery_level"
            android:textSize="13sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="16dp" />

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="#FF4CAF50" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/charging"
            android:textSize="13sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="16dp" />

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="#FFFF9800" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/discharging"
            android:textSize="13sp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/chart_tip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/chart_tip_text"
        android:textSize="11sp"
        android:textColor="#999"
        android:gravity="center"
        android:layout_marginTop="4dp" />

</LinearLayout>
